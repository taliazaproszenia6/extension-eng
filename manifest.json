{
    "manifest_version": 3,
    "name": "Language Translator & Reader",
    "version": "2.0.0",
    "description": "Select any word or sentence, click the translate icon, and get an instant translation. Choose your target language in the popup.",
    "key": "",
    "permissions": ["storage", "alarms", "notifications", "identity"],
    "host_permissions": [
        "https://identitytoolkit.googleapis.com/*",
        "https://firestore.googleapis.com/*",
        "https://securetoken.googleapis.com/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Language Translator & Reader - Settings"
    },
    "icons": {
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "css": ["styles.css"],
            "js": [
                "core.js",
                "content.js",
                "youtube.js",
                "netflix.js",
                "lookmovie2.js",
                "x.js",
                "hover.js"
            ],
            "run_at": "document_idle"
        }
    ]
}
